# ─── Sanity CMS ────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=your_read_token
SANITY_WEBHOOK_SECRET=your_webhook_secret

# ─── OGMS Integration ───────────────────────────────────────────────
OGMS_API_BASE_URL=https://ogms.westernbalkansfund.org/api/v1
OGMS_API_KEY=your_ogms_api_key

# ─── Partnership Platform ───────────────────────────────────────────
PARTNERSHIP_PLATFORM_BASE_URL=https://partners.westernbalkansfund.org/api/v1
PARTNERSHIP_PLATFORM_API_KEY=your_partnership_api_key

# ─── Site ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.westernbalkansfund.org
NEXT_PUBLIC_SITE_NAME=Western Balkans Fund

# ─── Email ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@westernbalkansfund.org
SMTP_PASS=your_smtp_password
CONTACT_EMAIL=info@westernbalkansfund.org

# ─── Analytics ──────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Revalidation ───────────────────────────────────────────────────
REVALIDATION_SECRET=your_revalidation_secret
